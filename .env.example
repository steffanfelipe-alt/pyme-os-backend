# Supabase / PostgreSQL
DATABASE_URL=postgresql://postgres:[TU-PASSWORD]@db.[TU-PROJECT-ID].supabase.co:5432/postgres
SUPABASE_URL=https://[TU-PROJECT-ID].supabase.co
SUPABASE_KEY=[TU-ANON-KEY]

# Auth propio (generá con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=tu-secret-key-aqui
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Frontend (necesario para links de reset de contraseña en emails)
FRONTEND_URL=https://tu-frontend.com

# CORS — separá múltiples orígenes con coma. Usar "*" solo para desarrollo local.
ALLOWED_ORIGINS=https://tu-frontend.com

# Logging
LOG_LEVEL=INFO

# Notificaciones por email (SMTP)
MAIL_FROM=sistema@tuestudio.com
MAIL_TO=contador@tuestudio.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASSWORD=tu-app-password

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Telegram Bot
TELEGRAM_BOT_TOKEN=tu-bot-token
TELEGRAM_WEBHOOK_URL=https://tu-dominio.com/webhooks/telegram
# Secret para validar que los updates vienen de Telegram (recomendado en producción)
# Generá con: python -c "import secrets; print(secrets.token_hex(16))"
TELEGRAM_WEBHOOK_SECRET=tu-webhook-secret

# Gmail OAuth2
GOOGLE_CLIENT_ID=tu-client-id
GOOGLE_CLIENT_SECRET=tu-client-secret
STUDIO_NAME=Nombre del Estudio
